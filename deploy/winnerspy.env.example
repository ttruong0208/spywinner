# Copy to /etc/winnerspy/env on VPS — chmod 600
# systemctl restart winnerspy-web winnerspy-chrome after edits

WINNERSPY_PRODUCTION=1
WINNERSPY_SAAS_MODE=1
WINNERSPY_ALLOW_REGISTER=1
WINNERSPY_APP_URL=https://winnerspy.app
WINNERSPY_CDP_URL=http://127.0.0.1:9222

WINNERSPY_SECRET=change-me-at-least-32-random-characters
WINNERSPY_ADMIN_PASSWORD=change-me-strong-admin-password
WINNERSPY_ADMIN_PATH=cp-winnerspy
WINNERSPY_ADMIN_IPS=

WINNERSPY_PAYPAL_ME=truonnguyen

WINNERSPY_RESEND_API_KEY=re_your_key_here
WINNERSPY_RESEND_FROM=WinnerSpy <onboarding@resend.dev>
